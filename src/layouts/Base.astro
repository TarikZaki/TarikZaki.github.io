---
import "../styles/global.css";
import { profile } from "../data/profile";
import profileImg from "../assets/profile.jpg";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${profile.name} — Front-End Developer | Angular · TypeScript`,
  description = `Front-End Developer specializing in enterprise Angular SPAs. Production experience with Reactive Forms, RxJS, state management, Signals, and Nx monorepos. Based in Alexandria, Egypt. Open to remote opportunities.`,
} = Astro.props;

const siteUrl = Astro.site!.toString().replace(/\/$/, "");
const ogImage = new URL(profileImg.src, Astro.site);
const ogImageAlt = `${profile.name} — Front-End Developer`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  jobTitle: profile.title,
  url: siteUrl,
  email: profile.email,
  telephone: profile.phone,
  image: ogImage.toString(),
  sameAs: [profile.links.github, profile.links.linkedin, profile.links.website],
  knowsAbout: [
    "Angular",
    "TypeScript",
    "JavaScript",
    "RxJS",
    "Angular Signals",
    "Reactive Forms",
    "JWT Authentication",
    "HTTP Interceptors",
    "State Management",
    "Lazy Loading",
    "Angular Control Flow",
    "Angular Material",
    "Jest",
    "Unit Testing",
    "Nx Monorepo",
    "REST API Integration",
    "SPA",
    "Responsive Design",
    "Agile",
    "Scrum",
    "Git",
    "HTML5",
    "CSS3",
    "SCSS",
  ],
  alumniOf: {
    "@type": "EducationalOrganization",
    name: "Alexandria University",
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Alexandria",
    addressCountry: "EG",
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="front-end developer, Angular developer, TypeScript, JavaScript, SPA, RxJS, Angular Signals, Reactive Forms, JWT authentication, HTTP interceptors, state management, lazy loading, Angular control flow, Angular Material, Nx monorepo, Jest, unit testing, REST API integration, responsive design, Agile, Scrum, Git, remote developer, Alexandria Egypt, software engineer" />
    <meta name="author" content={profile.name} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content={profile.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="profile:first_name" content="Tarek" />
    <meta property="profile:last_name" content="Zaki" />
    <meta property="profile:username" content="TarikZaki" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline>
      const stored = localStorage.getItem("theme");
      const dark =
        stored === "dark" ||
        (!stored && matchMedia("(prefers-color-scheme: dark)").matches);
      document.documentElement.classList.toggle("dark", dark);
    </script>
  </head>
  <body class="bg-paper font-body text-ink antialiased">
    <slot />
    <script>
      import Lenis from "lenis";

      if (matchMedia("(prefers-reduced-motion: no-preference)").matches) {
        new Lenis({ autoRaf: true, anchors: true });
      }
    </script>
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("revealed");
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.1 },
      );
      document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
    </script>
    <script>
      // Scroll-spy: highlight the sidebar link for the section in view
      const navLinks = Array.from(
        document.querySelectorAll<HTMLAnchorElement>("[data-nav]"),
      );
      const setActive = (id: string) => {
        for (const link of navLinks) {
          link.dataset.active = String(
            link.getAttribute("href") === `#${id}`,
          );
        }
      };
      const spy = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) setActive(entry.target.id);
          }
        },
        { rootMargin: "-45% 0px -50% 0px", threshold: 0 },
      );
      document
        .querySelectorAll("main section[id]")
        .forEach((el) => spy.observe(el));
    </script>
  </body>
</html>
