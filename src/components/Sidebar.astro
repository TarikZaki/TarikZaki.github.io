---
import { Image } from "astro:assets";
import { profile } from "../data/profile";
import profileImg from "../assets/profile.jpg";

const links = [
  { href: "#about", label: "About" },
  { href: "#experience", label: "Experience" },
  { href: "#projects", label: "Projects" },
  { href: "#skills", label: "Skills" },
  { href: "#education", label: "Education" },
  { href: "#contact", label: "Contact" },
];

const socials = [
  { href: profile.links.github, label: "GitHub" },
  { href: profile.links.linkedin, label: "LinkedIn" },
  { href: `mailto:${profile.email}`, label: "Email" },
];
---

<!-- Mobile top bar -->
<header
  class="glass sticky top-0 z-50 flex items-center justify-between px-5 py-3 lg:hidden"
>
  <a href="#top" class="flex items-center gap-3">
    <Image
      src={profileImg}
      alt={`Portrait of ${profile.name}`}
      width={72}
      height={72}
      loading="eager"
      class="size-9 rounded-full object-cover ring-1 ring-line"
    />
    <span class="font-display text-base font-medium tracking-tight">
      {profile.name}
    </span>
  </a>
  <div class="flex items-center gap-4">
    <details class="group relative">
      <summary
        aria-label="Open navigation menu"
        class="flex cursor-pointer list-none items-center text-soft transition-colors marker:content-[''] hover:text-ink [&::-webkit-details-marker]:hidden"
      >
        <svg class="size-6 group-open:hidden" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5"></path>
        </svg>
        <svg class="hidden size-6 group-open:block" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
        </svg>
      </summary>
      <ul class="glass absolute top-full right-0 mt-3 w-52 rounded-2xl p-2 text-sm text-soft shadow-2xl shadow-black/20">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                data-nav
                class="block rounded-xl px-4 py-2.5 transition-colors hover:bg-accent/10 hover:text-ink data-[active=true]:text-accent-text"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </details>
    <button
      class="theme-toggle cursor-pointer text-soft transition-colors hover:text-ink"
      type="button"
      aria-label="Toggle theme"
    >
      <svg class="hidden size-5 dark:block" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"></path>
      </svg>
      <svg class="size-5 dark:hidden" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"></path>
      </svg>
    </button>
  </div>
</header>

<!-- Desktop sidebar -->
<aside
  class="hidden lg:sticky lg:top-0 lg:flex lg:h-screen lg:w-80 lg:shrink-0 lg:flex-col lg:justify-between lg:border-r lg:border-line lg:px-8 lg:py-10"
>
  <div>
    <a href="#top" class="group inline-flex flex-col">
      <span class="relative w-fit">
        <span
          class="absolute -inset-1 rounded-full bg-gradient-to-tr from-accent to-accent-2 opacity-60 blur-md transition-opacity group-hover:opacity-90"
          aria-hidden="true"></span>
        <Image
          src={profileImg}
          alt={`Portrait of ${profile.name}`}
          width={240}
          height={240}
          loading="eager"
          class="relative size-24 rounded-full object-cover ring-1 ring-line"
        />
      </span>
      <span class="mt-5 font-display text-2xl font-medium tracking-tight">
        {profile.name}
      </span>
    </a>
    <p class="mt-1 text-sm font-medium text-gradient w-fit">
      {profile.title}
    </p>
    <p class="mt-4 flex items-center gap-2 text-xs text-soft">
      <span class="relative flex size-2">
        <span class="absolute inline-flex size-full animate-ping rounded-full bg-accent-2 opacity-75"></span>
        <span class="relative inline-flex size-2 rounded-full bg-accent-2"></span>
      </span>
      Available for work · {profile.location}
    </p>

    <nav class="mt-10">
      <ul class="space-y-1">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                data-nav
                class="group flex items-center gap-3 rounded-xl px-3 py-2 text-sm text-soft transition-colors hover:bg-accent/10 hover:text-ink data-[active=true]:bg-accent/10 data-[active=true]:text-accent-text"
              >
                <span
                  class="h-px w-6 bg-line transition-all group-hover:w-8 group-hover:bg-accent group-data-[active=true]:w-10 group-data-[active=true]:bg-gradient-to-r group-data-[active=true]:from-accent group-data-[active=true]:to-accent-2"
                  aria-hidden="true"></span>
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <div>
    <div class="flex flex-wrap gap-x-4 gap-y-2 text-xs text-soft">
      {
        socials.map((s) => (
          <a
            href={s.href}
            target={s.href.startsWith("http") ? "_blank" : undefined}
            rel="noopener"
            class="transition-colors hover:text-ink"
          >
            {s.label}
          </a>
        ))
      }
    </div>
    <div class="mt-4 flex items-center gap-3">
      <a
        href={profile.cvPath}
        download
        class="flex-1 rounded-full bg-gradient-to-r from-accent to-accent-2 px-4 py-2.5 text-center text-sm font-medium text-[#06060c] transition-opacity hover:opacity-90"
      >
        Download CV
      </a>
      <button
        class="theme-toggle grid size-10 shrink-0 cursor-pointer place-items-center rounded-full border border-line text-soft transition-colors hover:text-ink"
        type="button"
        aria-label="Toggle theme"
      >
        <svg class="hidden size-5 dark:block" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"></path>
        </svg>
        <svg class="size-5 dark:hidden" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"></path>
        </svg>
      </button>
    </div>
  </div>
</aside>

<script>
  document.querySelectorAll(".theme-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const dark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", dark ? "dark" : "light");
    });
  });

  const menu = document.querySelector<HTMLDetailsElement>("header details");
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.open = false;
    });
  });
</script>
