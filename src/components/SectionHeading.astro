---
interface Props {
  index: string;
  title: string;
}

const { index, title } = Astro.props;
---

<div class="mb-10 flex items-center gap-4">
  <span class="font-display text-sm font-medium text-accent-text">{index}</span>
  <h2 class="font-display text-2xl font-semibold tracking-tight sm:text-3xl">
    {title}
  </h2>
  <span
    class="h-px flex-1 bg-gradient-to-r from-line to-transparent"
    aria-hidden="true"></span>
</div>
