---
import { profile } from "../data/profile";

const links = [
  { href: "#about", label: "About" },
  { href: "#experience", label: "Experience" },
  { href: "#projects", label: "Projects" },
  { href: "#skills", label: "Skills" },
  { href: "#education", label: "Education" },
  { href: "#contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-line bg-paper/80 backdrop-blur">
  <nav class="relative mx-auto flex max-w-4xl items-center justify-between px-6 py-4">
    <a href="#top" class="font-display text-lg tracking-tight">
      {profile.name}
    </a>
    <div class="flex items-center gap-5">
      <ul class="hidden items-center gap-5 text-sm text-soft sm:flex">
        {
          links.map((link) => (
            <li>
              <a href={link.href} class="transition-colors hover:text-ink">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
      <details class="group relative sm:hidden">
        <summary
          aria-label="Open navigation menu"
          class="flex cursor-pointer list-none items-center text-soft transition-colors marker:content-[''] hover:text-ink [&::-webkit-details-marker]:hidden"
        >
          <svg
            class="size-5 group-open:hidden"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5"
            ></path>
          </svg>
          <svg
            class="hidden size-5 group-open:block"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
          </svg>
        </summary>
        <ul class="absolute top-full right-0 mt-3 w-48 divide-y divide-line border border-line bg-paper py-2 text-sm text-soft shadow-none">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="block px-4 py-2 transition-colors hover:text-ink"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </details>
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle theme"
        class="cursor-pointer text-soft transition-colors hover:text-ink"
      >
        <svg
          class="hidden size-5 dark:block"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"
          ></path>
        </svg>
        <svg
          class="size-5 dark:hidden"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"
          ></path>
        </svg>
      </button>
    </div>
  </nav>
</header>

<script>
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const dark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", dark ? "dark" : "light");
  });

  const menu = document.querySelector<HTMLDetailsElement>("nav details");
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.open = false;
    });
  });
</script>
