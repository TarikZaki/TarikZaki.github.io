---
import { profile } from "../data/profile";
import SectionHeading from "./SectionHeading.astro";
---

<section id="experience" class="reveal scroll-mt-8 py-16">
  <SectionHeading index="02" title="Experience" />
  <ol class="space-y-6">
    {
      profile.experience.map((job) => (
        <li class="glass group relative overflow-hidden rounded-3xl p-6 transition-colors hover:border-accent/40 sm:p-8">
          <span
            class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent to-transparent opacity-0 transition-opacity group-hover:opacity-100"
            aria-hidden="true"
          />
          <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
            <h3 class="font-display text-xl font-semibold tracking-tight">
              {job.role} <span class="text-accent-text">· {job.company}</span>
            </h3>
            <p class="rounded-full border border-line px-3 py-1 text-xs text-soft">
              {job.period}
            </p>
          </div>
          <p class="mt-2 text-sm text-soft">{job.location}</p>
          <ul class="mt-5 grid gap-3 text-[15px] leading-relaxed text-soft">
            {job.highlights.map((point) => (
              <li class="flex gap-3">
                <span class="mt-2 size-1.5 shrink-0 rounded-full bg-gradient-to-r from-accent to-accent-2" aria-hidden="true" />
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </li>
      ))
    }
  </ol>
</section>
