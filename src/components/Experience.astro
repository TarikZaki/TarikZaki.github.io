---
import { profile } from "../data/profile";
import SectionHeading from "./SectionHeading.astro";
---

<section class="reveal mx-auto max-w-4xl px-6 py-16">
  <SectionHeading id="experience" title="Experience" />
  <ol class="space-y-14 border-l border-line pl-8">
    {
      profile.experience.map((job) => (
        <li class="relative">
          <span
            class="absolute top-1.5 -left-[2.35rem] size-2.5 rounded-full bg-accent"
            aria-hidden="true"
          />
          <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
            <h3 class="font-display text-xl tracking-tight">
              {job.role} · {job.company}
            </h3>
            <p class="text-sm text-soft">{job.period}</p>
          </div>
          <p class="mt-1 text-sm text-soft">{job.location}</p>
          <ul class="mt-4 max-w-2xl space-y-2.5 text-[15px] leading-relaxed text-soft">
            {job.highlights.map((point) => (
              <li class="flex gap-3">
                <span class="mt-0.5 text-accent" aria-hidden="true">
                  ·
                </span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </li>
      ))
    }
  </ol>
</section>
