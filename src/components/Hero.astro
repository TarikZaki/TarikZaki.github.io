---
import { Image } from "astro:assets";
import { profile } from "../data/profile";
import profileImg from "../assets/profile.jpg";
---

<section id="top" class="mx-auto max-w-4xl px-6 pt-20 pb-24 sm:pt-28">
  <div class="flex flex-col-reverse items-start gap-10 sm:flex-row sm:items-center sm:justify-between">
    <div class="max-w-xl">
      <h1 class="font-display text-4xl leading-tight tracking-tight sm:text-5xl">
        {profile.name}
      </h1>
      <p class="mt-2 text-sm font-medium text-accent-text">
        {profile.title}
      </p>
      <p class="mt-5 leading-relaxed text-soft">
        {profile.tagline}
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a
          href={profile.cvPath}
          download
          class="rounded-full bg-ink px-5 py-2.5 text-sm font-medium text-paper transition-opacity hover:opacity-80"
        >
          Download CV
        </a>
        <a
          href={profile.links.github}
          target="_blank"
          rel="noopener"
          class="text-sm text-soft underline decoration-line underline-offset-4 transition-colors hover:text-ink hover:decoration-accent"
        >
          GitHub
        </a>
        <a
          href={profile.links.linkedin}
          target="_blank"
          rel="noopener"
          class="text-sm text-soft underline decoration-line underline-offset-4 transition-colors hover:text-ink hover:decoration-accent"
        >
          LinkedIn
        </a>
        <a
          href={`mailto:${profile.email}`}
          class="text-sm text-soft underline decoration-line underline-offset-4 transition-colors hover:text-ink hover:decoration-accent"
        >
          Email
        </a>
      </div>
    </div>
    <Image
      src={profileImg}
      alt={`Portrait of ${profile.name}`}
      width={480}
      height={480}
      loading="eager"
      class="size-36 rounded-full border border-line object-cover sm:size-48"
    />
  </div>
</section>
