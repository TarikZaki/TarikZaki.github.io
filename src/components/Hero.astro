---
import { profile } from "../data/profile";
---

<section
  id="top"
  class="flex min-h-[70vh] scroll-mt-8 flex-col justify-center py-20 lg:min-h-screen lg:py-0"
>
  <p class="font-display text-sm font-medium tracking-wide text-accent-text">
    Hi, I'm {profile.name} —
  </p>
  <h1
    class="mt-4 max-w-3xl font-display text-4xl leading-[1.1] font-semibold tracking-tight sm:text-5xl lg:text-6xl"
  >
    I build <span class="text-gradient">enterprise Angular</span> apps that are
    fast, tested, and built to last.
  </h1>
  <p class="mt-6 max-w-xl leading-relaxed text-soft">
    {profile.tagline}
  </p>
  <div class="mt-9 flex flex-wrap items-center gap-4">
    <a
      href="#projects"
      class="glow-ring rounded-full bg-gradient-to-r from-accent to-accent-2 px-6 py-3 text-sm font-medium text-[#06060c] transition-opacity hover:opacity-90"
    >
      View Projects
    </a>
    <a
      href="#contact"
      class="glass rounded-full px-6 py-3 text-sm font-medium transition-colors hover:text-accent-text"
    >
      Get in touch
    </a>
  </div>

  <dl class="mt-14 grid max-w-lg grid-cols-3 gap-4">
    <div class="glass rounded-2xl p-4">
      <dt class="text-2xl font-semibold text-gradient font-display">84%</dt>
      <dd class="mt-1 text-xs text-soft">Test coverage (Jest)</dd>
    </div>
    <div class="glass rounded-2xl p-4">
      <dt class="text-2xl font-semibold text-gradient font-display">Nx</dt>
      <dd class="mt-1 text-xs text-soft">Monorepo architecture</dd>
    </div>
    <div class="glass rounded-2xl p-4">
      <dt class="text-2xl font-semibold text-gradient font-display">Signals</dt>
      <dd class="mt-1 text-xs text-soft">Modern Angular</dd>
    </div>
  </dl>
</section>
