---
import { profile } from "../data/profile";
import SectionHeading from "./SectionHeading.astro";
---

<section class="reveal mx-auto max-w-4xl px-6 py-16">
  <SectionHeading id="contact" title="Contact" />
  <div class="max-w-2xl">
    <p class="leading-relaxed text-soft">
      Open to interesting problems and good conversations. The fastest way to
      reach me:
    </p>
    <a
      href={`mailto:${profile.email}`}
      class="mt-5 inline-block font-display text-2xl tracking-tight underline decoration-line underline-offset-8 transition-colors hover:decoration-accent sm:text-3xl"
    >
      {profile.email}
    </a>
    <div class="mt-8 flex flex-wrap gap-x-8 gap-y-3 text-sm text-soft">
      <a
        href={`tel:${profile.phoneHref}`}
        class="transition-colors hover:text-ink"
      >
        {profile.phone}
      </a>
      <a
        href={profile.links.github}
        target="_blank"
        rel="noopener"
        class="transition-colors hover:text-ink"
      >
        GitHub
      </a>
      <a
        href={profile.links.linkedin}
        target="_blank"
        rel="noopener"
        class="transition-colors hover:text-ink"
      >
        LinkedIn
      </a>
    </div>
  </div>
</section>

<footer class="mx-auto max-w-4xl border-t border-line px-6 py-8">
  <p class="text-xs text-soft">
    © {new Date().getFullYear()} {profile.name} · Built with Astro
  </p>
</footer>
