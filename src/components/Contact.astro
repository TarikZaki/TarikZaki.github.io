---
import { profile } from "../data/profile";
import SectionHeading from "./SectionHeading.astro";
---

<section id="contact" class="reveal scroll-mt-8 py-16">
  <SectionHeading index="06" title="Contact" />
  <div class="glass glow-ring overflow-hidden rounded-3xl p-8 sm:p-10">
    <p class="max-w-xl leading-relaxed text-soft">
      Open to interesting problems and good conversations. The fastest way to
      reach me:
    </p>
    <a
      href={`mailto:${profile.email}`}
      class="mt-5 inline-block font-display text-2xl font-semibold tracking-tight text-gradient transition-opacity hover:opacity-80 sm:text-4xl"
    >
      {profile.email}
    </a>
    <div class="mt-8 flex flex-wrap gap-3 text-sm">
      <a
        href={`tel:${profile.phoneHref}`}
        class="rounded-full border border-line px-4 py-2 text-soft transition-colors hover:border-accent/40 hover:text-ink"
      >
        {profile.phone}
      </a>
      <a
        href={profile.links.github}
        target="_blank"
        rel="noopener"
        class="rounded-full border border-line px-4 py-2 text-soft transition-colors hover:border-accent/40 hover:text-ink"
      >
        GitHub
      </a>
      <a
        href={profile.links.linkedin}
        target="_blank"
        rel="noopener"
        class="rounded-full border border-line px-4 py-2 text-soft transition-colors hover:border-accent/40 hover:text-ink"
      >
        LinkedIn
      </a>
      <a
        href={profile.links.website}
        target="_blank"
        rel="noopener"
        class="rounded-full border border-line px-4 py-2 text-soft transition-colors hover:border-accent/40 hover:text-ink"
      >
        Website
      </a>
    </div>
  </div>
</section>

<footer class="border-t border-line py-8">
  <p class="text-xs text-soft">
    © {new Date().getFullYear()} {profile.name} · Built with Astro
  </p>
</footer>
