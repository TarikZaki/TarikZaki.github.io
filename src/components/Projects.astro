---
import { profile } from "../data/profile";
import SectionHeading from "./SectionHeading.astro";
---

<section class="reveal mx-auto max-w-4xl px-6 py-16">
  <SectionHeading id="projects" title="Projects" />
  <ul class="max-w-2xl divide-y divide-line border-y border-line">
    {
      profile.projects.map((project) => (
        <li class="py-6">
          <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
            <h3 class="font-display text-lg tracking-tight">{project.name}</h3>
            {project.note && (
              <span class="text-xs text-soft">{project.note}</span>
            )}
          </div>
          {
            (project.demo || project.github) && (
              <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-sm">
                {
                  project.demo && (
                    <a
                      href={project.demo}
                      target="_blank"
                      rel="noopener"
                      class="text-soft underline decoration-line underline-offset-4 transition-colors hover:text-ink hover:decoration-accent"
                    >
                      Live Demo<span aria-hidden="true"> ↗</span>
                    </a>
                  )
                }
                {
                  project.github && (
                    <a
                      href={project.github}
                      target="_blank"
                      rel="noopener"
                      class="text-soft underline decoration-line underline-offset-4 transition-colors hover:text-ink hover:decoration-accent"
                    >
                      GitHub<span aria-hidden="true"> ↗</span>
                    </a>
                  )
                }
              </div>
            )
          }
          <ul class="mt-4 max-w-xl space-y-2.5 text-sm leading-relaxed text-soft">
            {project.highlights.map((point) => (
              <li class="flex gap-3">
                <span class="mt-0.5 text-accent" aria-hidden="true">
                  ·
                </span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
          <p class="mt-3 text-xs text-soft">
            {project.tags.join(" · ")}
          </p>
        </li>
      ))
    }
  </ul>
</section>
