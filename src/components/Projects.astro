---
import { profile } from "../data/profile";
import SectionHeading from "./SectionHeading.astro";
---

<section id="projects" class="reveal scroll-mt-8 py-16">
  <SectionHeading index="03" title="Projects" />
  <div class="grid gap-6 sm:grid-cols-2">
    {
      profile.projects.map((project) => (
        <article class="glass group flex flex-col rounded-3xl p-6 transition-colors hover:border-accent/40 sm:p-7">
          <div class="flex items-start justify-between gap-4">
            <h3 class="font-display text-lg font-semibold tracking-tight">
              {project.name}
            </h3>
            <span
              class="grid size-9 shrink-0 place-items-center rounded-full border border-line text-accent-text transition-colors group-hover:border-accent/50"
              aria-hidden="true"
            >
              <svg class="size-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5 19.5 4.5m0 0H9m10.5 0V15" />
              </svg>
            </span>
          </div>
          {project.note && (
            <span class="mt-1 text-xs text-soft">{project.note}</span>
          )}
          <ul class="mt-4 grid gap-2.5 text-sm leading-relaxed text-soft">
            {project.highlights.map((point) => (
              <li class="flex gap-3">
                <span class="mt-2 size-1.5 shrink-0 rounded-full bg-gradient-to-r from-accent to-accent-2" aria-hidden="true" />
                <span>{point}</span>
              </li>
            ))}
          </ul>
          <ul class="mt-5 flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <li class="rounded-full border border-line bg-accent/5 px-2.5 py-1 text-xs text-accent-text">
                {tag}
              </li>
            ))}
          </ul>
          {(project.demo || project.github) && (
            <div class="mt-6 flex flex-wrap gap-x-4 gap-y-2 border-t border-line pt-4 text-sm">
              {project.demo && (
                <a
                  href={project.demo}
                  target="_blank"
                  rel="noopener"
                  class="font-medium text-accent-text transition-opacity hover:opacity-80"
                >
                  Live Demo<span aria-hidden="true"> ↗</span>
                </a>
              )}
              {project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener"
                  class="text-soft transition-colors hover:text-ink"
                >
                  GitHub<span aria-hidden="true"> ↗</span>
                </a>
              )}
            </div>
          )}
        </article>
      ))
    }
  </div>
</section>
